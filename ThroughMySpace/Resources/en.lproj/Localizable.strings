// ----- ConditionType.detailDescription -----
"condition.visualField.detail" = "A condition where increased eye pressure gradually damages the optic nerve.\n\nThe visual field narrows slowly, often going unnoticed until it has advanced significantly.\nApproximately 4 million patients in Japan.";
"condition.colorBlind.detail" = "A condition where cone cells that sense certain colors are absent or weakened.\n\nThe most common type causes reds, greens, browns, and oranges to appear similar.\nAffects approximately 5% of men in Japan.";
"condition.cataract.detail" = "A condition where the eye's lens becomes cloudy, causing light to scatter and vision to blur.\n\nMainly caused by aging, affecting approximately 70% of people over 60.\nA characteristic symptom is seeing halos around light sources.";
"condition.rp.detail" = "A hereditary disease where the retina's photoreceptor cells gradually degenerate.\n\nBegins with night blindness and slowly progresses to loss of peripheral vision.\nApproximately 30,000 patients in Japan. No fundamental cure currently exists.";
"condition.presbyopia.detail" = "A condition where the lens loses elasticity with age, making it difficult to focus on nearby objects.\n\nTypically begins in the 40s and affects nearly everyone by their 60s.\nMost noticeable when reading books, looking at a phone, or seeing close-up objects.";
"condition.astigmatism.detail" = "A condition caused by an irregular curve in the cornea or lens, preventing light from focusing at a single point.\n\nMild astigmatism is common. A characteristic symptom is light appearing streaked or blurred, especially at night.\nCan be corrected with glasses or contact lenses.";

// ----- ConditionType.title (scotoma / floaters) -----
"condition.scotoma.title" = "Central Scotoma";
"condition.floaters.title" = "Floaters";

// ----- ConditionType.shortDescription (scotoma / floaters) -----
"condition.scotoma.short" = "Experience central vision loss where your point of focus becomes blurred";
"condition.floaters.short" = "Experience thread-like shadows drifting across your field of vision";

// ----- ConditionType.detailDescription (scotoma / floaters) -----
"condition.scotoma.detail" = "A condition caused by macular degeneration, where the center of the visual field is lost.\n\nThe area you look directly at becomes blurred or dark, making reading, recognizing faces, and fine detail work difficult.\nAge-related macular degeneration is a leading cause of visual impairment in Japan.";
"condition.floaters.detail" = "Shadows cast by debris in the vitreous humor, the gel-like substance filling the eye.\n\nAppear as threads, dots, or rings drifting across your field of vision. Most noticeable against bright, uniform backgrounds.\nUsually harmless with age, but a sudden increase may indicate retinal detachment.";

